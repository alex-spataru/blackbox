{
   "name": "RM42 Magnetic Brake (FNN)",
   "rnn": false,
   "seed": 42,
   "device": "cpu",
   "max_epochs": 200,
   "batch_size": 8,
   "weight_decay": 1e-4,
   "hidden_layers": 3,
   "dropout_rate": 0.15,
   "num_derivatives": 1,
   "learning_rate": 0.001,
   "neurons_per_layer": 256,
   "early_stop_patience": 25,
   "early_stop_threshold": 1e-5,
   "val_ratio": 0.15,
   "test_ratio": 0.15,
   "csv_encoding": "ISO-8859-1",
   "plot_save_path": "./outputs/FNN_Model/Plots",
   "model_save_path": "./outputs/FNN_Model/Models",
   "test_cases_path": "./outputs/FNN_Model/Test Cases",
   "training_data_path": "./outputs/FNN_Model/Training Data",
   "held_out_path": "./outputs/FNN_Model/Held Out",
   "test_vectors_path": "./cfg/RM42 Magnetic Brake/Test Vectors",
   "raw_data_path": "./cfg/RM42 Magnetic Brake/Experimental Data",
   "operation_modes": {
      "0": "USER",
      "1": "STEP",
      "2": "RAMP",
      "3": "PSIN",
      "4": "STOPPED"
   },
   "normalization_parameters": {
      "RPM": 12000,
      "Distance": 30,
      "Current": 4000,
      "Reference": 100,
      "Temperature": 60
   },
   "units": {
      "RPM": "RPM",
      "Distance": "mm",
      "Current": "mA",
      "Reference": "%",
      "Temperature": "C"
   },
   "axis_labels": {
       "RPM": "Motor speed (RPM)",
       "Distance": "Distance (mm)",
       "Reference": "Speed reference (%)",
       "Current": "Current consumption (mA)",
       "Temperature": "Magnet temperature (C)"
   },
   "inputs": [
      "Reference",
      "Distance",
      "Temperature"
   ],
   "outputs": [
      "RPM",
      "Current"
   ],
   "lp_filter": {
      "cutoff_freq": 20,
      "sample_freq": 50
   },
   "gaussian_filter": [
      {
         "column": "Current",
         "peak_sigma": 0.2,
         "base_sigma": 5,
         "blend_width": 10
      }
   ],
   "constant_signals": [
      "Distance",
      "Temperature"
   ],
   "scheduled_sampling": {
      "start_prob": 0.9,
      "end_prob": 0.0,
      "decay_epochs": 40
   },
   "lr_scheduler": {
      "factor": 0.5,
      "patience": 8,
      "min_lr": 1e-6
   },
   "val_smoothing": 0.7,
   "grad_clip": 5.0,
   "feedback_noise_std": 0.01
}
